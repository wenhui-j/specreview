{
  "name": "specreview",
  "version": "1.0.12",
  "description": "Multi-role code review skill for AI coding assistants — /specreview <spec-name>",
  "keywords": [
    "specreview",
    "code-review",
    "claude-code",
    "ai",
    "skill",
    "openspec",
    "code-quality",
    "automated-review",
    "linting"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "specreview": "dist/bin/specreview.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0"
  },
  "files:note": "⚠️ Keep this list in sync with package contents. The 'files' field controls what gets published to npm."
}
